# Vittoria — copy to .env (local) or set in Vercel project settings (prod).
# Do NOT commit real values. .env is in .gitignore.

# ─────────────────────────────────────────────────────────────────────────
# Postgres (required) — Supabase recommended in prod.
# DATABASE_URL is the runtime / pooled URL (port 6543).
# DIRECT_URL is the migrations URL (port 5432, session-mode pooler).
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────
# Auth.js v5 (required) — generate with: openssl rand -base64 32
# Set NEXTAUTH_URL to your deployment URL in prod (https://your-app.vercel.app).
# ─────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=""
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# ─────────────────────────────────────────────────────────────────────────
# Token-at-rest encryption (required) — 32 bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER rotate without re-encrypting all AdAccount.accessTokenEnc rows.
# ─────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────────────────
# Cron route guard (required if you want scheduled syncs).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Vercel cron sends Authorization: Bearer <CRON_SECRET> on the configured schedule.
# ─────────────────────────────────────────────────────────────────────────
CRON_SECRET=""

# ─────────────────────────────────────────────────────────────────────────
# OpenRouter (required for Vittoria chat + report narrative).
# One key, multiple models routed per task — see src/lib/llm/agents.ts.
# Get a key at https://openrouter.ai/keys
# ─────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_APP_TITLE="Vittoria"
OPENROUTER_APP_URL="http://localhost:3001"

# ─────────────────────────────────────────────────────────────────────────
# Google Ads (optional) — only set when you connect a Google MCC account.
# Required: developer token + OAuth client. Optional: login customer id (MCC).
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""

# ─────────────────────────────────────────────────────────────────────────
# Meta — optional for MVP (we use system-user token paste). Required if
# we ever wire OAuth so clients can authorize themselves.
# ─────────────────────────────────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""

# ─────────────────────────────────────────────────────────────────────────
# Outgoing email (optional). If unset, password-reset links are logged to
# the server console.
# ─────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────
# First-run seed credentials. CHANGE the password before deploy.
# ─────────────────────────────────────────────────────────────────────────
SEED_MANAGER_EMAIL="admin@example.com"
SEED_MANAGER_PASSWORD=""
